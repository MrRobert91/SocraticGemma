# SocraticGemma Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# API Configuration
# ===========================================

# OpenRouter API Key (required)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===========================================
# Model Configuration
# ===========================================

# Fast model - Gemma 4 26B MoE (only 3.8B active params, near-31B quality)
GEMMA_MODEL_FAST=google/gemma-4-26b-a4b-it

# Accurate model - Gemma 4 31B dense
GEMMA_MODEL_ACCURATE=google/gemma-4-31b-it

# Model used for evaluation
EVALUATOR_MODEL=google/gemma-4-26b-a4b-it

# OpenRouter base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ===========================================
# Session Configuration
# ===========================================

# Session time-to-live in hours (default: 4)
SESSION_TTL_HOURS=4

# ===========================================
# Authentication
# ===========================================

# Secret key for signing JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — change this before deploying!
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars_change_in_production

# Comma-separated list of allowed frontend origins for CORS.
# Add http://localhost:3000 for local development.
CORS_ORIGINS=https://socraticgemma-js7p6v.sliplane.app,http://localhost:3000

# ===========================================
# Database Configuration
# ===========================================

# Path to the SQLite database file.
# Mount a persistent volume at /data and set this variable to survive container restarts.
# In Sliplane: add volume "socratic_gemma_data" → mount path /data, then set DB_PATH=/data/conversations.db
DB_PATH=/data/conversations.db

# ===========================================
# RAG Configuration
# ===========================================

# Enable RAG (Retrieval-Augmented Generation) for context augmentation
# Requires chromadb package: pip install socraticgemma[rag]
RAG_ENABLED=false

# ===========================================
# Debug Configuration
# ===========================================

# Enable debug mode to see full prompts in logs
DEBUG_PROMPTS=false

# ===========================================
# Frontend Configuration
# ===========================================

# Backend URL for server-side proxy (runtime, used by Next.js Route Handler for local dev)
BACKEND_URL=https://your-backend.sliplane.app

# Public backend URL embedded in the browser bundle (BUILD-TIME variable).
# Must be set as a build env var in Sliplane/CI so Next.js injects it during `npm run build`.
# Without this, the browser falls back to the /api/backend proxy (which breaks SSE streaming).
NEXT_PUBLIC_API_URL=https://your-backend.sliplane.app
