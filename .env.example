# SocraticGemma Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# API Configuration
# ===========================================

# OpenRouter API Key (required)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===========================================
# Model Configuration
# ===========================================

# Fast model for quick responses (2B parameter model)
GEMMA_MODEL_FAST=google/gemma-4-e2b-it

# Accurate model for better quality responses (27B parameter model)
GEMMA_MODEL_ACCURATE=google/gemma-4-27b-it

# Model used for evaluation
EVALUATOR_MODEL=google/gemma-4-e2b-it

# OpenRouter base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ===========================================
# Session Configuration
# ===========================================

# Session time-to-live in hours (default: 4)
SESSION_TTL_HOURS=4

# ===========================================
# RAG Configuration
# ===========================================

# Enable RAG (Retrieval-Augmented Generation) for context augmentation
# Requires chromadb package: pip install socraticgemma[rag]
RAG_ENABLED=false

# ===========================================
# Debug Configuration
# ===========================================

# Enable debug mode to see full prompts in logs
DEBUG_PROMPTS=false

# ===========================================
# Frontend Configuration
# ===========================================

# Backend URL for server-side proxy (runtime, used by Next.js Route Handler for local dev)
BACKEND_URL=https://your-backend.sliplane.app

# Public backend URL embedded in the browser bundle (BUILD-TIME variable).
# Must be set as a build env var in Sliplane/CI so Next.js injects it during `npm run build`.
# Without this, the browser falls back to the /api/backend proxy (which breaks SSE streaming).
NEXT_PUBLIC_API_URL=https://your-backend.sliplane.app
